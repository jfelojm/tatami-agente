# Variables para Railway / Render (Fase 1 — webhook WhatsApp)
# Copie cada valor desde su .env local. NO suba este archivo con secretos a git.

# --- Obligatorias ---
SUPABASE_URL=
SUPABASE_KEY=
SPREADSHEET_ID=
GOOGLE_CREDENTIALS_JSON=
ANTHROPIC_API_KEY=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
DASHBOARD_TOKEN=

# --- Google Drive (facturas por WhatsApp) ---
GOOGLE_DRIVE_FACTURAS_FOLDER_ID=

# --- Allowlists WhatsApp (solo digitos, separados por coma) ---
ALLOWLIST_SOCIO=
ALLOWLIST_CONSULTA=
ALLOWLIST_OPERATIVO=

# --- Alertas salientes (opcional en nube) ---
ALERTA_WA_FELIPE=
ALERTA_WA_MOISES=
ALERTA_WA_EDUARDO=
ALERTA_WA_JACKY=

# --- Facturas / conteo ---
FACTURA_SESSION_BACKEND=supabase
FACTURA_SHEETS_INGEST_SECRET=
CONTEO_SHEETS_INGEST_SECRET=
RECONCILIAR_TOL_ABS=0.05

# --- Local: usar archivo en vez de JSON ---
