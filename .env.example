# Copia este archivo como .env y completa valores reales.

# Google
# GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json
# En nube (Railway): pegue el JSON completo en GOOGLE_CREDENTIALS_JSON
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
SPREADSHEET_ID=
GOOGLE_DRIVE_FACTURAS_FOLDER_ID=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_ANON_KEY=

# Anthropic
ANTHROPIC_API_KEY=

# Smart Menu
SMART_MENU_BASE_URL=
SMART_MENU_PHPSESSID=

# WhatsApp Cloud API
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_SKIP_SIGNATURE=1
# Roles WhatsApp (solo dígitos con código país, sin +)
ALLOWLIST_SOCIO=
ALLOWLIST_ADMIN_COMPRAS=
ALLOWLIST_JEFE_BARRA=
ALLOWLIST_JEFE_COCINA=

# Periodo pruebas legacy (0=producción). Stock negativo: aviso al operador + ALERTA_WA_FELIPE
TATAMI_PERIODO_PRUEBAS_COCINA=0
ALLOWLIST_STAFF_BARRA=
ALLOWLIST_STAFF_COCINA=
# Alertas WA individuales
ALERTA_WA_FELIPE=
ALERTA_WA_MARY=
ALERTA_WA_MOISES=
ALERTA_WA_ISRAEL=
ALERTA_WA_EDUARDO=
ALERTA_WA_JACKY=
# Ping WA al terminar cada paso del pipeline (prueba). 0 = desactivado
# TATAMI_WA_PING_PASOS=0
# TATAMI_WA_PING_DESTINO=

# Pipeline / reconciliación ventas (opcional)
# RECONCILIAR_TOL_ABS=0.05
# TATAMI_ALERT_WEBHOOK_URL=https://...
# TATAMI_ALERT_LOG_PATH=C:\ruta\logs\tatami_alertas.log
# WhatsApp alertas (mismo WHATSAPP_PHONE_NUMBER_ID + WHATSAPP_ACCESS_TOKEN que arriba)
# ALERTA_WA_FELIPE=593XXXXXXXXX
# ALERTA_WA_MOISES=593XXXXXXXXX
# Confirmación bodega ingreso factura (cocina/externa vs barra/consignación)
# ALERTA_WA_JACKY=593XXXXXXXXX
# ALERTA_WA_EDUARDO=593XXXXXXXXX
# TATAMI_WA_SKIP=1
# Alertas stock negativo tras descargo (suspendidas por defecto; descomentar para reactivar):
# TATAMI_ALERT_STOCK_NEGATIVO=1
# Alertas bajo PAR + negativos MPs proveedores BD_PROV.Tipo=Barra
# TATAMI_ALERT_INVENTARIO_BARRA=1
# Preview (revisión): solo este número; quitar o comentar para pasar a Eduardo
# ALERTA_WA_INVENTARIO_BARRA=593XXXXXXXXX
# Órdenes compra barra sugeridas (post-pipeline, revisión)
# TATAMI_ALERT_ORDENES_COMPRA_BARRA=1
# ALERTA_WA_ORDENES_BARRA=593XXXXXXXXX,593XXXXXXXXX,593XXXXXXXXX
# Prueba solo un número (prioridad sobre ALERTA_WA_ORDENES_BARRA):
# ALERTA_WA_ORDENES_BARRA_PREVIEW=593XXXXXXXXX

# Facturas: no registrar mov/stock desde XML con fecha anterior a este día
# TATAMI_FECHA_MIN_INGRESO_FACTURA=2026-05-29

# Descargo ventas: líneas SUB en BD_RECETAS_DETALLE (requiere sync_stock_subrecetas_maestro)
# DESCARGO_SUBRECETAS=0
# DESCARGO_SUBRECETAS=1

# Dashboard web (GET /dashboard?token=... y /api/dashboard/ventas)
DASHBOARD_TOKEN=tatami2026

# Descarga automática facturas recibidas SRI
# Tareas Windows: TatamiFacturasSRI_AM (10:00) y TatamiFacturasSRI_PM (18:00) = descarga+proceso
# Pipeline horario (cada hora): solo procesa cola DESCARGADO (--solo-proceso)
# Pipeline horario: solo procesa cola DESCARGADO; descarga portal en tareas 10:00/18:00
# PIPELINE_SRI_SOLO_PROCESO=1
SRI_RUC=
SRI_CERT_P12_PATH=credentials/tatami_firma.p12
SRI_CERT_PASSWORD=
SRI_PORTAL_USER=
SRI_PORTAL_PASSWORD=
# Días previos + hoy para consultar portal (ej. 4 -> hoy 17-jun busca 13-jun..17-jun)
SRI_VENTANA_DIAS=4
SRI_AMBIENTE=produccion
# Sesión Playwright guardada tras login manual (python procesar_facturas_sri.py --init-portal-session)
# SRI_PORTAL_STORAGE_STATE=credentials/sri_portal_state.json
# SRI_PORTAL_BROWSER=chrome
# Chrome visible sin clic manual (mejor captcha invisible SRI). Headless suele fallar.
SRI_PORTAL_HEADLESS=0
# manual = usted clic CONSULTAR por dia (recomendado) | auto = sin intervencion
SRI_CONSULTA_MODO=manual
SRI_CONSULTA_REINTENTOS=3
SRI_CAPTCHA_TIMEOUT_SEC=300
# chrome | msedge
SRI_PORTAL_BROWSER=chrome
# SRI_CAPTCHA_2CAPTCHA_KEY=
SRI_RECAPTCHA_ENTERPRISE=1
# portal | soap | auto (auto = lista portal + XML vía SOAP, más fiable que diálogo XML)
SRI_DESCARGA_MODO=auto
# SRI_CAPTCHA_TIMEOUT_SEC=180

